# Set DRY_RUN=true to print the report instead of sending email.
DRY_RUN=true

# Gmail example. Use a Gmail App Password, not your normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_sender_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password
EMAIL_FROM=your_sender_email@gmail.com
EMAIL_TO=your_receiving_email@example.com
